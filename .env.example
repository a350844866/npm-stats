# Copy this file to .env and fill in your values
# cp .env.example .env

# MySQL connection
MYSQL_HOST=your_mysql_host
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=npm_stats

# Nginx Proxy Manager server (SSH)
NPM_HOST=your_npm_server_ip
NPM_USER=ubuntu
NPM_PASSWORD=your_ssh_password

# Web login credentials
ADMIN_USER=admin
ADMIN_PASS=change_this_password

# Flask session key (generate a random string)
SECRET_KEY=change-this-to-a-random-secret-string
